<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',sans-serif;background:#1a2e1a;color:#2d3a2d;line-height:1.7}
.c{max-width:1050px;margin:0 auto;padding:15px}

/* HERO */
.hero{background:linear-gradient(135deg,#1a2e1a 0%,#2d4a2d 40%,#3d6b3d 100%);color:#fff;padding:50px 30px;border-radius:12px;margin-bottom:20px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'🏔️⛺🌲🏕️🌿🔥';position:absolute;top:10px;left:50%;transform:translateX(-50%);font-size:28px;letter-spacing:15px;opacity:.3}
.hero h1{font-size:30px;margin:30px 0 8px;letter-spacing:1px}
.hero .sub{color:#a8d5a8;font-size:16px;margin-bottom:5px}
.hero .client{background:rgba(255,255,255,.15);display:inline-block;padding:8px 25px;border-radius:30px;margin-top:12px;font-size:14px;backdrop-filter:blur(5px)}

/* SECTIONS */
.s{background:#fff;padding:28px;border-radius:12px;margin-bottom:18px;box-shadow:0 4px 20px rgba(0,0,0,.15)}
.s h2{color:#2d4a2d;font-size:21px;margin-bottom:15px;padding-bottom:10px;border-bottom:3px solid #e8a840;display:flex;align-items:center;gap:10px}

/* INTRO */
.intro-msg{background:linear-gradient(135deg,#f0f7f0,#e8f5e8);padding:20px;border-radius:8px;border-left:4px solid #3d6b3d;color:#2d3a2d;font-size:14px;margin-bottom:15px}

/* PAIN POINTS */
.pain{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:15px 0}
@media(max-width:600px){.pain{grid-template-columns:1fr}}
.pain-item{padding:12px 15px;border-radius:8px;font-size:13px;display:flex;align-items:center;gap:10px}
.pain-item.bad{background:#fef2f2;border-left:3px solid #dc2626;color:#7f1d1d}
.pain-item.good{background:#f0fdf4;border-left:3px solid #16a34a;color:#14532d}

/* NUMBERS */
.nums{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:15px 0}
@media(max-width:600px){.nums{grid-template-columns:1fr}}
.num-card{padding:20px;border-radius:10px;text-align:center;color:#fff}
.num-card.red{background:linear-gradient(135deg,#dc2626,#b91c1c)}
.num-card.green{background:linear-gradient(135deg,#16a34a,#15803d)}
.num-card.gold{background:linear-gradient(135deg,#e8a840,#ca8a04)}
.num-card .big{font-size:28px;font-weight:800}
.num-card .lbl{font-size:11px;opacity:.9;margin-top:4px}

/* PACKAGES */
.pkgs{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin:15px 0}
@media(max-width:768px){.pkgs{grid-template-columns:1fr}}
.pkg{border-radius:10px;overflow:hidden;border:2px solid #e5e7eb;transition:transform .3s,box-shadow .3s}
.pkg:hover{transform:translateY(-4px);box-shadow:0 8px 25px rgba(0,0,0,.12)}
.pkg.feat{border-color:#e8a840;transform:scale(1.03)}
.pkg.feat:hover{transform:scale(1.03) translateY(-4px)}
.pkg-head{padding:20px;text-align:center;color:#fff}
.pkg-head.t1{background:linear-gradient(135deg,#3d6b3d,#2d4a2d)}
.pkg-head.t2{background:linear-gradient(135deg,#e8a840,#ca8a04)}
.pkg-head.t3{background:linear-gradient(135deg,#5b3a1a,#3d2810)}
.pkg-name{font-size:20px;font-weight:800;letter-spacing:1px}
.pkg-price{font-size:28px;font-weight:800;margin:8px 0 4px}
.pkg-badge{background:rgba(255,255,255,.25);padding:3px 14px;border-radius:20px;font-size:11px;display:inline-block}
.pkg-body{padding:18px}
.pkg-body ul{list-style:none;padding:0}
.pkg-body li{padding:6px 0;font-size:13px;color:#444;display:flex;align-items:flex-start;gap:8px}
.pkg-body li::before{content:"✓";color:#16a34a;font-weight:700;flex-shrink:0}
.pkg.feat .pkg-body li::before{color:#e8a840}
.pkg-cta{display:block;margin:12px 18px 18px;padding:10px;border:none;border-radius:6px;font-size:13px;font-weight:700;cursor:pointer;text-align:center;color:#fff}
.pkg-cta.c1{background:#3d6b3d}
.pkg-cta.c2{background:#e8a840}
.pkg-cta.c3{background:#5b3a1a}

/* COMPARISON TABLE */
.tbl{width:100%;border-collapse:collapse;margin:15px 0;font-size:13px}
.tbl th{background:#2d4a2d;color:#fff;padding:10px;text-align:left}
.tbl td{padding:10px;border-bottom:1px solid #eee}
.tbl tr:nth-child(even){background:#f9faf9}
.tbl .ck{color:#16a34a;font-weight:700;font-size:16px}

/* TOOLS */
.tools{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin:15px 0}
.tool{background:linear-gradient(135deg,#f0f7f0,#e8f5e8);padding:14px;border-radius:8px;text-align:center;border:1px solid #d1e7d1}
.tool .ico{font-size:24px;margin-bottom:5px}
.tool .nm{font-weight:700;color:#2d4a2d;font-size:13px}
.tool .fn{color:#666;font-size:11px}

/* TIMELINE */
.tl-item{display:flex;gap:15px;margin-bottom:18px;padding-bottom:18px;border-bottom:1px dashed #d1e7d1}
.tl-item:last-child{border:none}
.tl-dot{background:#3d6b3d;color:#fff;width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:16px}
.tl-txt h4{color:#2d4a2d;font-size:14px;margin-bottom:3px}
.tl-txt p{color:#666;font-size:13px}

/* PRICING */
.price-box{background:linear-gradient(135deg,#f0f7f0,#e8f5e8);padding:20px;border-radius:10px;margin:15px 0;border:2px solid #3d6b3d}
.price-box h4{color:#2d4a2d;margin-bottom:10px;font-size:15px}
.price-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #d1e7d1;font-size:13px}
.price-row:last-child{border:none;font-weight:700;color:#2d4a2d;font-size:15px}
.price-row .amt{color:#e8a840;font-weight:700}

/* HIGHLIGHT */
.hl{padding:15px 18px;border-radius:8px;margin:15px 0;font-size:13px;line-height:1.7}
.hl.camp{background:linear-gradient(135deg,#fef9ee,#fdf0d5);border-left:4px solid #e8a840}
.hl.forest{background:linear-gradient(135deg,#f0f7f0,#e0f0e0);border-left:4px solid #3d6b3d}

/* BONUS */
.bonus{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:15px 0}
